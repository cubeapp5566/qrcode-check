# AES-256-GCM 加密金鑰，必須為 32 bytes UTF-8 字串
# 前後端都使用同一把 key；前端版本會被 bundle 進靜態 JS，
# 使用者打開 DevTools 即可看見 — 僅作為傳輸混淆，並非真 secret。
# 注意：docker-compose 會做變數展開，值內的 `$` 必須用 `$$` 跳脫
ASSET_CIPHER_KEY=ChangeMe!Fixed@Key#2024$$Data!XX

# 同一把 key 給前端 (Vite 只暴露 VITE_ 前綴的變數到 bundle)
VITE_ASSET_CIPHER_KEY=ChangeMe!Fixed@Key#2024$$Data!XX

# 刪除盤點任務需要的密碼
DELETE_TASK_PASSWORD=change-me
